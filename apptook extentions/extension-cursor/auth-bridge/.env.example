# Server
PORT=8787

# Google Sheets
SHEET_ID=your_google_sheet_id
SERVICE_ACCOUNT_PATH=C:/path/to/service-account.json
USER_SHEET_RANGE=users!A2:F
LICENSE_SHEET_RANGE=licenses!A2:E

# JWT secrets (MUST be long random strings and different values)
# Recommended: inject via process env at runtime (do not store in .env on disk)
ACCESS_JWT_SECRET=replace_with_random_access_secret
REFRESH_JWT_SECRET=replace_with_random_refresh_secret

# Admin API key for privileged endpoints (optional, required for /admin/revoke-user-sessions)
ADMIN_API_KEY=replace_with_random_admin_key

# Token TTL
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=14d

# Refresh token store
REFRESH_STORE_PATH=./.refresh-store.json
