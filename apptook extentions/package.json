{
  "name": "cursorpool",
  "displayName": "Cursor Activation",
  "description": "Cursor Activation, Auto Account Switching",
  "publisher": "keg1255",
  "version": "1.0.94",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.23.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./bootstrap.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorpool.openUserPanel",
        "title": "Open User Panel"
      },
      {
        "command": "cursorpool.showLogs",
        "title": "Show Log Panel"
      },
      {
        "command": "cursorpool.refreshUserStatus",
        "title": "Refresh User Status",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorpool-sidebar",
          "title": "CursorPool",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "cursorpool-sidebar": [
        {
          "type": "webview",
          "id": "cursorpool.userPanel",
          "name": "User Center",
          "when": "true"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorpool.refreshUserStatus",
          "when": "view == cursorpool.userPanel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "CursorPool",
      "properties": {
        "cursorpool.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "enumDescriptions": [
            "Detailed debug information",
            "General information",
            "Warning information",
            "Error information"
          ],
          "description": "Set log level"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node -e \"console.log('skip prepublish build')\"",
    "compile": "webpack",
    "start": "webpack --watch",
    "watch": "webpack --watch",
    "package": "cross-env NODE_ENV=production webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build:runtime-vsix": "node scripts/build-runtime-vsix.js"
  },
  "devDependencies": {
    "@types/bson": "^1.0.11",
    "@types/fs-extra": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.23.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.1",
    "javascript-obfuscator": "^4.1.1",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1",
    "webpack-obfuscator": "^3.5.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.35",
    "axios": "^0.24.0",
    "bson": "^1.1.6",
    "fs-extra": "8.1",
    "https-proxy-agent": "^7.0.4",
    "iconv-lite": "^0.7.0",
    "socks-proxy-agent": "^8.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keg1255/windsurf-pool.git"
  },
  "keywords": [
    "Cursor Activation"
  ],
  "author": "keg1255",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/keg1255/windsurf-pool/issues"
  },
  "homepage": "https://github.com/keg1255/windsurf-pool#readme"
}
